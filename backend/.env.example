# ===== DATABASE (Aiven MySQL) =====
DB_HOST=your-host.aivencloud.com
DB_PORT=15483
DB_NAME=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=your_password_here

# ===== JWT =====
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400000

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ===== BREVO SMTP (OTP / Forgot Password Emails) =====
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=your_brevo_account_email@example.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_api_key
BREVO_FROM_EMAIL=your_brevo_account_email@example.com
BREVO_FROM_NAME=LMS Platform
